-- Drag Logic
local dragging = false
local dragStartPos, frameStartPos

frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or
       input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStartPos = input.Position
        frameStartPos = frame.Position
    end
end)

frame.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or
       input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or
                     input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStartPos
        frame.Position = UDim2.new(
            frameStartPos.X.Scale,
            frameStartPos.X.Offset + delta.X,
            frameStartPos.Y.Scale,
            frameStartPos.Y.Offset + delta.Y
        )
    end
end)

-- Toggle
button.MouseButton1Click:Connect(function()
    antiSitEnabled = not antiSitEnabled
    if antiSitEnabled then
        button.BackgroundColor3 = Color3.fromRGB(220, 50, 50)
        button.Text = "AntiSit: ON"
    else
        button.BackgroundColor3 = Color3.fromRGB(50, 180, 50)
        button.Text = "AntiSit: OFF"
        -- Restore seat collision when disabled
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("Seat") or obj:IsA("VehicleSeat") then
                obj.CanCollide = true
            end
        end
    end
end)

-- Cache seats instead of scanning every frame
local seats = {}

local function cacheSeat(obj)
    if obj:IsA("Seat") or obj:IsA("VehicleSeat") then
        seats[obj] = true
        obj.AncestryChanged:Connect(function()
            if not obj:IsDescendantOf(workspace) then
                seats[obj] = nil
            end
        end)
    end
end

for _, obj in ipairs(workspace:GetDescendants()) do
    cacheSeat(obj)
end

workspace.DescendantAdded:Connect(function(obj)
    cacheSeat(obj)
end)

-- Heartbeat: antisit + seat noclip only
RunService.Heartbeat:Connect(function()
    if antiSitEnabled then
        if humanoid.Sit then
            humanoid.Sit = false
        end
        for seat in pairs(seats) do
            seat.CanCollide = false
        end
    end
end)
